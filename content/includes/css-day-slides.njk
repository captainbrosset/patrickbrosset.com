<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/slides/CSSDay-2026/favicon.svg" type="image/svg+xml">
    <title>Fun with grid-lanes - CSSDay 2026 - {{ title }}</title>
    <style>
      @view-transition {
        navigation: auto;
      }

      .notes {
        display: none;
      }
    </style>
  </head>
  <body>
    {{ content | safe }}

    {% if notes %}
      <aside class="notes">
        {{ notes | safe }}
      </aside>
    {% endif %}
  </body>
</html>
